---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import PageHero from '../components/PageHero.astro';
import teamPhoto from '../assets/photos/team-monteur.jpg';
import pageHeroPhoto from '../assets/photos/page-hero-woning.jpg';
import { site } from '../data/site';
import { locations } from '../data/locations';
---

<BaseLayout
  title="Over ons: airco-specialist in Noord-Brabant | Best Aircotechniek"
  description="Uw persoonlijke airco-installateur in Best en omgeving. Eerlijk advies, netjes werk en nazorg. Maak kennis met Best Aircotechniek."
>
  <PageHero
    title="Over ons"
    description="Best Aircotechniek staat voor kwaliteit, betrouwbaarheid en een koel resultaat waar u jarenlang van geniet."
    image={pageHeroPhoto}
  />

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <h2 class="section-heading">Wie wij zijn</h2>
          <p class="mt-6 text-lg leading-relaxed text-slate-600">
            Best Aircotechniek is een jong en ambitieus bedrijf gespecialiseerd in het plaatsen van airconditioningsystemen voor particulieren en bedrijven. Wij geloven dat iedereen recht heeft op een comfortabel binnenklimaat, zomer én winter.
          </p>
          <p class="mt-4 text-lg leading-relaxed text-slate-600">
            Met oog voor detail en respect voor uw woning of pand, zorgen wij voor een nette installatie en duidelijke communicatie van begin tot eind.
          </p>
        </div>
        <div class="overflow-hidden rounded-2xl bg-slate-100 shadow-sm ring-1 ring-slate-200">
          <Image
            src={teamPhoto}
            alt="Professionele monteur van Best Aircotechniek in uniform voor een woning"
            width={640}
            height={480}
            class="aspect-[4/3] h-full w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center">Waarom klanten voor ons kiezen</h2>
      <div class="mt-12 grid gap-8 sm:grid-cols-3">
        <div class="rounded-2xl bg-white p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-slate-900">Persoonlijk contact</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">
            U spreekt direct met ons. Geen callcenters en geen lange wachttijden. Korte lijnen en duidelijke afspraken.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-slate-900">Netjes werken</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">
            Wij laten uw woning of pand netjes achter. Professionele afwerking en zorgvuldige montage staan voorop.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-slate-900">Eerlijk advies</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">
            Wij adviseren wat écht past bij uw situatie. Geen onnodige upsells, wel de beste oplossing voor uw budget.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-brand-200 bg-brand-50 p-8 sm:p-12">
        <div class="max-w-3xl">
          <div class="gold-accent-line"></div>
          <h2 class="section-heading mt-6">Werkgebied</h2>
          <p class="section-subheading">
            Wij installeren airconditioning in {site.region}. Klik op uw plaats voor meer informatie, of bekijk ons
            <a href="/airco-installatie-noord-brabant" class="font-semibold text-brand-700 underline">volledige werkgebied</a>.
          </p>
        </div>

        <ul class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {
            locations.map((loc) => (
              <li>
                <a
                  href={`/airco-installatie-${loc.slug}`}
                  class="flex items-center gap-3 rounded-xl border border-brand-100 bg-white px-4 py-3 shadow-sm transition hover:border-gold-400 hover:shadow-md"
                >
                  <span
                    class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-brand-800 text-white"
                    aria-hidden="true"
                  >
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"
                      />
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                      />
                    </svg>
                  </span>
                  <span class="font-semibold text-brand-900">{loc.city}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
