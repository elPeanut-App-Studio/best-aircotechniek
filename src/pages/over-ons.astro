---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import { site, serviceAreas } from '../data/site';
---

<BaseLayout
  title="Over ons"
  description="Leer Best Aircotechniek kennen. Uw lokale specialist in airco-installatie met vakmanschap en persoonlijke service."
>
  <section class="page-hero py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl">Over ons</h1>
      <p class="mt-4 max-w-2xl text-lg text-brand-100">
        Best Aircotechniek staat voor kwaliteit, betrouwbaarheid en een koel resultaat waar u jarenlang van geniet.
      </p>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <h2 class="section-heading">Wie wij zijn</h2>
          <p class="mt-6 text-lg leading-relaxed text-slate-600">
            Best Aircotechniek is een jong en ambitieus bedrijf gespecialiseerd in het plaatsen van airconditioningsystemen voor particulieren en bedrijven. Wij geloven dat iedereen recht heeft op een comfortabel binnenklimaat, zomer én winter.
          </p>
          <p class="mt-4 text-lg leading-relaxed text-slate-600">
            Met oog voor detail en respect voor uw woning of pand, zorgen wij voor een nette installatie en duidelijke communicatie van begin tot eind.
          </p>
        </div>
        <div class="rounded-2xl bg-slate-100 p-12">
          <div class="flex aspect-video items-center justify-center rounded-xl bg-slate-200">
            <div class="text-center text-slate-500">
              <svg class="mx-auto h-16 w-16 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
              </svg>
              <p class="mt-2 text-sm">Foto placeholder</p>
              <p class="text-xs">Voeg later een team- of bedrijfsfoto toe</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center">Waarom klanten voor ons kiezen</h2>
      <div class="mt-12 grid gap-8 sm:grid-cols-3">
        <div class="rounded-2xl bg-white p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-slate-900">Persoonlijk contact</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">
            U spreekt direct met ons. Geen callcenters en geen lange wachttijden. Korte lijnen en duidelijke afspraken.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-slate-900">Netjes werken</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">
            Wij laten uw woning of pand netjes achter. Professionele afwerking en zorgvuldige montage staan voorop.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-8 shadow-sm">
          <h3 class="text-lg font-semibold text-slate-900">Eerlijk advies</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">
            Wij adviseren wat écht past bij uw situatie. Geen onnodige upsells, wel de beste oplossing voor uw budget.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-brand-200 bg-brand-50 p-8 sm:p-12">
        <div class="max-w-3xl">
          <div class="gold-accent-line"></div>
          <h2 class="section-heading mt-6">Werkgebied</h2>
          <p class="section-subheading">
            Wij installeren airconditioning in {site.region}. Woont u in de omgeving van een van de volgende plaatsen? Neem dan contact met ons op.
          </p>
        </div>

        <ul class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {
            serviceAreas.map((place) => (
              <li class="flex items-center gap-3 rounded-xl border border-brand-100 bg-white px-4 py-3 shadow-sm">
                <span
                  class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-brand-800 text-white"
                  aria-hidden="true"
                >
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                    />
                  </svg>
                </span>
                <span class="font-semibold text-brand-900">{place}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
