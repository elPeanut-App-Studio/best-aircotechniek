---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CTASection from '../../../../components/CTASection.astro';
import { auxModels, auxSizes } from '../../../../data/aux-products';

export function getStaticPaths() {
  return auxModels.flatMap((model) =>
    auxSizes.map((size) => ({ params: { model: model.slug, size: size.slug }, props: { model, size } })),
  );
}

const { model, size } = Astro.props;
const ss = model.sizeSpecs[size.slug];

// Per-vermogen data voor de client-side wisselaar (scrollpositie blijft behouden)
const sizesData = auxSizes.map((s) => ({
  slug: s.slug,
  kw: s.kw,
  volume: s.volume,
  room: s.room,
  koel: model.sizeSpecs[s.slug].koel,
  verw: model.sizeSpecs[s.slug].verw,
  seer: model.sizeSpecs[s.slug].seer,
  scop: model.sizeSpecs[s.slug].scop,
}));

// Spec rows met icoon; id op de waardes die per vermogen wisselen
const rows = [
  { icon: 'koelen', label: 'Koelvermogen', value: ss.koel, badge: model.labelKoelen, id: 'val-koel' },
  { icon: 'verwarmen', label: 'Verwarmingsvermogen', value: ss.verw, badge: model.labelVerwarmen, id: 'val-verw' },
  { icon: 'wifi', label: 'Wifi', value: 'WiFi module ingebouwd' },
  { icon: 'ruimte', label: 'Geschikt voor', value: `Ruimtes tot ${size.volume}`, id: 'val-ruimte' },
  { icon: 'rendement', label: 'Rendement', value: `SEER ${ss.seer} / SCOP ${ss.scop}`, id: 'val-rendement' },
  { icon: 'swing', label: 'Luchtstroom', value: model.specs[0].value },
];

const extra = [...model.specs.slice(1), { label: 'Garantie', value: '2 jaar' }];
const btnBase = 'size-btn rounded-xl px-5 py-2.5 font-semibold transition ';
const btnActive = 'border-2 border-brand-700 bg-brand-50 text-brand-900';
const btnInactive = 'border border-slate-300 text-slate-700 hover:border-brand-500 hover:text-brand-900';
---

<BaseLayout
  title={`AUX ${model.name} ${size.kw} airco | Best Aircotechniek`}
  description={`AUX ${model.name} ${size.kw}: ${ss.koel} koelen (${model.labelKoelen}), geschikt voor ${size.room.toLowerCase()}. Laten installeren door Best Aircotechniek.`}
>
  <section class="pt-8 pb-16 sm:pt-10 sm:pb-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-slate-500" aria-label="Kruimelpad">
        <a href="/merken/aux" class="hover:text-brand-700">AUX</a>
        <span class="px-1">/</span>
        <a href={`/merken/aux/${model.slug}`} class="hover:text-brand-700">{model.name}</a>
        <span class="px-1">/</span>
        <span id="crumb-size" class="text-slate-700">{size.kw}</span>
      </nav>

      <div class="mt-4">
        <p class="text-sm font-semibold uppercase tracking-wider text-gold-600">{model.tier}</p>
        <h1 id="page-title" class="mt-1 text-3xl font-extrabold tracking-tight text-brand-900 sm:text-4xl">
          AUX {model.name} {size.kw}
        </h1>
        <p id="page-sub" class="mt-2 text-slate-600">
          Geschikt voor {size.room.toLowerCase()} ({size.volume}).
        </p>
      </div>

      <div class="mt-8 grid gap-10 lg:grid-cols-2 lg:items-start">
        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white p-6 shadow-sm lg:sticky lg:top-28">
          <img src={model.photo} alt={`AUX ${model.name} airconditioner`} width="800" height="800" loading="eager" class="mx-auto h-auto w-full max-w-md object-contain" />
        </div>

        <div>
          <p class="text-sm font-semibold text-slate-700">Kies uw vermogen</p>
          <div class="mt-3 flex flex-wrap gap-3">
            {
              auxSizes.map((s) => (
                <a
                  href={`/merken/aux/${model.slug}/${s.slug}`}
                  data-size={s.slug}
                  class={btnBase + (s.slug === size.slug ? btnActive : btnInactive)}
                >
                  {s.kw}
                </a>
              ))
            }
          </div>

          <h2 class="section-heading mt-10">Specificaties</h2>
          <dl class="mt-5 border-t border-slate-200">
            {
              rows.map((r) => (
                <div class="flex items-center justify-between gap-4 border-b border-slate-200 py-3">
                  <dt class="flex items-center gap-3 text-slate-600">
                    <img src={`/spec-icons/${r.icon}.png`} alt="" width="24" height="24" class="h-6 w-6 shrink-0" />
                    {r.label}
                  </dt>
                  <dd class="flex items-center gap-2 text-right font-semibold text-brand-900">
                    <span id={r.id}>{r.value}</span>
                    {r.badge && (
                      <span class={`rounded px-2 py-0.5 text-xs font-bold text-white ${r.badge === 'A++' ? 'bg-[#2f9e44]' : 'bg-[#94b820]'}`}>
                        {r.badge}
                      </span>
                    )}
                  </dd>
                </div>
              ))
            }
          </dl>

          <h3 class="mt-8 text-lg font-bold text-brand-900">Meer kenmerken</h3>
          <ul class="mt-3 space-y-2 text-sm">
            {
              extra.map((e) => (
                <li class="flex gap-2">
                  <span aria-hidden="true" class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-gold-500" />
                  <span class="text-slate-600">
                    <span class="font-semibold text-brand-900">{e.label}:</span> {e.value}
                  </span>
                </li>
              ))
            }
          </ul>

          <div class="mt-8">
            <a href="/contact" class="btn-primary inline-flex">Vraag een offerte aan</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title={`AUX ${model.name} laten installeren?`}
    description="Best Aircotechniek verzorgt advies, levering en een vakkundige montage. Vraag een vrijblijvende offerte aan."
  />

  <script
    define:vars={{
      sizesData,
      modelSlug: model.slug,
      modelName: model.name,
      btnBase,
      btnActive,
      btnInactive,
    }}
  >
    const links = Array.from(document.querySelectorAll('a[data-size]'));
    function applySize(slug) {
      const d = sizesData.find((s) => s.slug === slug);
      if (!d) return;
      const setText = (id, text) => {
        const el = document.getElementById(id);
        if (el) el.textContent = text;
      };
      setText('val-koel', d.koel);
      setText('val-verw', d.verw);
      setText('val-ruimte', 'Ruimtes tot ' + d.volume);
      setText('val-rendement', 'SEER ' + d.seer + ' / SCOP ' + d.scop);
      setText('crumb-size', d.kw);
      setText('page-title', 'AUX ' + modelName + ' ' + d.kw);
      setText('page-sub', 'Geschikt voor ' + d.room.toLowerCase() + ' (' + d.volume + ').');
      links.forEach((a) => {
        a.className = btnBase + (a.dataset.size === slug ? btnActive : btnInactive);
      });
      document.title = 'AUX ' + modelName + ' ' + d.kw + ' airco | Best Aircotechniek';
      history.replaceState(null, '', '/merken/aux/' + modelSlug + '/' + slug);
    }
    links.forEach((a) =>
      a.addEventListener('click', (e) => {
        e.preventDefault();
        applySize(a.dataset.size);
      }),
    );
  </script>
</BaseLayout>
