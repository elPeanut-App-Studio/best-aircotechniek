---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import CTASection from '../../../components/CTASection.astro';
import { auxModels, auxSizes, auxShared } from '../../../data/aux-products';
import pageHeroPhoto from '../../../assets/photos/page-hero-woning.jpg';

export function getStaticPaths() {
  return auxModels.map((model) => ({ params: { model: model.slug }, props: { model } }));
}

const { model } = Astro.props;

// Iconen voor de 5 modelkenmerken (zelfde volgorde als model.specs)
const specIcons = ['swing', 'luchtzuivering', 'zelfreiniging', 'verwarmen', 'design'];
---

<BaseLayout
  title={`AUX ${model.name} airco laten installeren | Best Aircotechniek`}
  description={`AUX ${model.name}: ${model.intro} Beschikbaar in 2,5 / 3,5 / 5,0 / 7,0 kW. Laten installeren door Best Aircotechniek.`}
>
  <PageHero title={`AUX ${model.name}`} description={model.intro} image={pageHeroPhoto} />

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-slate-500" aria-label="Kruimelpad">
        <a href="/merken/aux" class="hover:text-brand-700">AUX</a>
        <span class="px-1">/</span>
        <span class="text-slate-700">{model.name}</span>
      </nav>

      <div class="mt-8 grid gap-10 lg:grid-cols-2 lg:items-center">
        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <img src={model.photo} alt={`AUX ${model.name} airconditioner`} width="800" height="800" loading="eager" class="mx-auto h-auto w-full max-w-md object-contain" />
        </div>
        <div>
          <p class="text-sm font-semibold uppercase tracking-wider text-gold-600">{model.tier}</p>
          <h2 class="section-heading mt-2">Kenmerken</h2>
          <dl class="mt-5 border-t border-slate-200">
            <div class="flex items-center justify-between gap-4 border-b border-slate-200 py-3">
              <dt class="flex items-center gap-3 text-slate-600">
                <img src="/spec-icons/rendement.png" alt="" width="24" height="24" class="h-6 w-6 shrink-0" />
                SEER (tot) / SCOP
              </dt>
              <dd class="flex flex-wrap items-center justify-end gap-1.5 text-right font-semibold text-brand-900">
                <span>{model.seer}</span>
                <span class="rounded bg-[#2f9e44] px-2 py-0.5 text-xs font-bold text-white">{model.labelKoelen}</span>
                <span class="text-slate-400">/</span>
                <span>{model.scop}</span>
                <span class="rounded bg-[#94b820] px-2 py-0.5 text-xs font-bold text-white">{model.labelVerwarmen}</span>
              </dd>
            </div>
            {
              model.specs.map((s, i) => (
                <div class="flex items-center justify-between gap-4 border-b border-slate-200 py-3">
                  <dt class="flex items-center gap-3 text-slate-600">
                    <img src={`/spec-icons/${specIcons[i]}.png`} alt="" width="24" height="24" class="h-6 w-6 shrink-0" />
                    {s.label}
                  </dt>
                  <dd class="text-right font-semibold text-brand-900">{s.value}</dd>
                </div>
              ))
            }
          </dl>
          <p class="mt-4 text-sm text-slate-500">Standaard bij elke AUX: {auxShared.join(' · ')}.</p>
        </div>
      </div>

      <h2 class="section-heading mt-16">Beschikbare vermogens</h2>
      <p class="mt-3 text-slate-600">Kies het vermogen dat past bij uw ruimte. Klik door voor alle details.</p>
      <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          auxSizes.map((size) => (
            <a
              href={`/merken/aux/${model.slug}/${size.slug}`}
              class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-gold-400 hover:shadow-md"
            >
              <p class="text-2xl font-bold text-brand-900">{size.kw}</p>
              <p class="mt-2 min-h-[2.5rem] text-sm text-slate-600">{size.room}</p>
              <p class="mt-1 text-sm text-slate-500">{size.volume} · {size.area}</p>
              <span class="mt-auto pt-4 text-sm font-semibold text-brand-700 transition group-hover:text-brand-900">
                Bekijk details
                <span aria-hidden="true" class="transition group-hover:translate-x-0.5">&rarr;</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection
    title={`Interesse in de AUX ${model.name}?`}
    description="Wij adviseren u graag over het juiste vermogen en verzorgen de complete installatie. Vraag een vrijblijvende offerte aan."
  />
</BaseLayout>
