---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTASection from '../../components/CTASection.astro';
import { brands } from '../../data/brands';
import heroPhoto from '../../assets/photos/page-hero-woning.jpg';

export function getStaticPaths() {
  return brands.map((b) => ({ params: { brand: b.slug }, props: { brand: b } }));
}

const { brand } = Astro.props;
---

<BaseLayout
  title={`${brand.name} airco laten installeren | Best Aircotechniek`}
  description={`${brand.name} airconditioning laten installeren door Best Aircotechniek in Noord-Brabant. ${brand.tagline}`}
>
  <PageHero title={`${brand.name} airconditioning`} description={brand.tagline} image={heroPhoto} />

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="gold-accent-line"></div>
      <h2 class="section-heading mt-6">Over {brand.name}</h2>
      <p class="mt-4 text-lg leading-relaxed text-slate-600">
        Binnenkort vindt u hier meer informatie over de {brand.name}-modellen die wij installeren, met de
        kenmerken en voordelen. Wilt u nu al persoonlijk advies of een vrijblijvende offerte? Neem gerust
        contact met ons op, dan kijken we samen welk model het beste bij uw woning past.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/contact" class="btn-primary inline-flex">Vraag een offerte aan</a>
        {
          brand.brochure && (
            <a href={brand.brochure} download class="btn-secondary inline-flex items-center gap-2">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              Download de {brand.name}-brochure (pdf)
            </a>
          )
        }
        <a href="/airco-installatie" class="btn-secondary inline-flex">Bekijk airco-installatie</a>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
