---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CTASection from '../../components/CTASection.astro';
import { brands } from '../../data/brands';
import { auxModels } from '../../data/aux-products';
import heroPhoto from '../../assets/photos/page-hero-woning.jpg';

export function getStaticPaths() {
  return brands.map((b) => ({ params: { brand: b.slug }, props: { brand: b } }));
}

const { brand } = Astro.props;
const models = brand.slug === 'aux' ? auxModels : [];
// highlights shown per model card: luchtstroom, luchtzuivering, verwarmen
const highlightLabels = ['Luchtstroom & comfort', 'Luchtzuivering', 'Verwarmen bij extreme kou'];
---

<BaseLayout
  title={`${brand.name} airco laten installeren | Best Aircotechniek`}
  description={`${brand.name} airconditioning laten installeren door Best Aircotechniek in Noord-Brabant. ${brand.tagline}`}
>
  <PageHero title={`${brand.name} airconditioning`} description={brand.tagline} image={heroPhoto} />

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="gold-accent-line"></div>
      <h2 class="section-heading mt-6">Over {brand.name}</h2>
      {
        models.length > 0 ? (
          <p class="mt-4 text-lg leading-relaxed text-slate-600">
            AUX biedt drie series, elk met eigen kenmerken en comfort. Hieronder vindt u per model de
            belangrijkste functies. Klik door voor de beschikbare vermogens en alle specificaties.
          </p>
        ) : (
          <p class="mt-4 text-lg leading-relaxed text-slate-600">
            Binnenkort vindt u hier meer informatie over de {brand.name}-modellen die wij installeren, met de
            kenmerken en voordelen. Wilt u nu al persoonlijk advies of een vrijblijvende offerte? Neem gerust
            contact met ons op, dan kijken we samen welk model het beste bij uw woning past.
          </p>
        )
      }
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/contact" class="btn-primary inline-flex">Vraag een offerte aan</a>
        {
          brand.brochure && (
            <a href={brand.brochure} download class="btn-secondary inline-flex items-center gap-2">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              Download de {brand.name}-brochure (pdf)
            </a>
          )
        }
        <a href="/airco-installatie" class="btn-secondary inline-flex">Bekijk airco-installatie</a>
      </div>
    </div>
  </section>

  {
    models.length > 0 && (
      <section class="border-t border-slate-200 bg-slate-50 py-16 sm:py-20">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
          <h2 class="section-heading">De drie AUX-series</h2>
          <div class="mt-10 grid grid-cols-1 gap-8 lg:grid-cols-3">
            {models.map((m) => (
              <a
                href={`/merken/aux/${m.slug}`}
                class="group flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-gold-400 hover:shadow-md"
              >
                <img
                  src={m.photo}
                  alt={`AUX ${m.name} airconditioner`}
                  width="600"
                  height="600"
                  loading="lazy"
                  class="mx-auto h-40 w-auto object-contain"
                />
                <p class="mt-4 text-xs font-semibold uppercase tracking-wider text-gold-600">{m.tier}</p>
                <h3 class="mt-1 text-xl font-bold text-brand-900">AUX {m.name}</h3>
                <p class="mt-2 leading-relaxed text-slate-600">{m.intro}</p>
                <ul class="mt-4 space-y-2 text-sm">
                  {highlightLabels.map((label) => {
                    const spec = m.specs.find((s) => s.label === label);
                    return (
                      <li class="flex gap-2">
                        <span aria-hidden="true" class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-gold-500" />
                        <span class="text-slate-600">{spec?.value}</span>
                      </li>
                    );
                  })}
                </ul>
                <span class="mt-5 text-sm font-semibold text-brand-700 transition group-hover:text-brand-900">
                  Bekijk modellen
                  <span aria-hidden="true" class="transition group-hover:translate-x-0.5">&rarr;</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <CTASection />
</BaseLayout>
