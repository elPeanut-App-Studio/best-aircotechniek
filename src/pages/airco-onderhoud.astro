---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTASection from '../components/CTASection.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import FaqSchema from '../components/FaqSchema.astro';
import contactHeroPhoto from '../assets/photos/modern-woning-airco.jpg';

const benefits = [
  {
    title: 'Efficiënt en zuinig',
    description:
      'Een schone, goed afgestelde airco verbruikt minder energie en levert meer comfort. Onderhoud verlaagt uw energiekosten.',
  },
  {
    title: 'Hygiënisch en gezond',
    description:
      'Bij onderhoud reinigen en controleren wij de filters en het systeem, zodat u schone lucht houdt zonder vervelende geurtjes.',
  },
  {
    title: 'Garantie behouden',
    description:
      'Uw installatiegarantie van 2 jaar blijft alleen geldig wanneer de airco jaarlijks door een vakman wordt onderhouden.',
  },
  {
    title: 'Langere levensduur',
    description:
      'Periodiek onderhoud voorkomt storingen en verlengt de levensduur van uw airco, zodat u er langer plezier van heeft.',
  },
];

const faq = [
  {
    question: 'Voor welke airco’s verzorgen jullie onderhoud?',
    answer:
      'Wij verzorgen het onderhoud voor airco’s die wij zelf hebben geïnstalleerd. Zo kennen wij uw systeem en houden we het in topconditie.',
  },
  {
    question: 'Waarom is jaarlijks onderhoud belangrijk?',
    answer:
      'Jaarlijks onderhoud houdt uw airco efficiënt, hygiënisch en storingsvrij. Daarnaast is het de voorwaarde om uw installatiegarantie van 2 jaar geldig te houden.',
  },
  {
    question: 'Wat gebeurt er tijdens een onderhoudsbeurt?',
    answer:
      'Wij reinigen en controleren de filters, inspecteren het systeem op lekkages en slijtage, controleren de werking en stellen waar nodig bij, zodat alles weer optimaal functioneert.',
  },
];
---

<BaseLayout
  title="Airco onderhoud | Best Aircotechniek"
  description="Airco onderhoud door Best Aircotechniek voor door ons geplaatste airco’s. Houd uw systeem efficiënt, hygiënisch en uw garantie geldig. Actief in Noord-Brabant."
>
  <PageHero
    title="Airco onderhoud"
    description="Houd uw airco efficiënt, hygiënisch en storingsvrij, en behoud uw installatiegarantie met jaarlijks onderhoud."
    image={contactHeroPhoto}
  />

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="gold-accent-line"></div>
        <h2 class="section-heading mt-6">Onderhoud aan uw airco</h2>
        <p class="mt-4 text-lg leading-relaxed text-slate-600">
          Een airco gaat jaren mee, maar alleen met goed onderhoud blijft hij efficiënt en hygiënisch werken.
          Best Aircotechniek verzorgt het jaarlijks onderhoud voor airco’s die wij zelf hebben geïnstalleerd. Zo
          kennen wij uw systeem en weten we precies waar we op moeten letten.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-slate-600">
          Goed onderhoud is bovendien de voorwaarde om uw installatiegarantie van 2 jaar geldig te houden. Heeft u
          uw airco door ons laten plaatsen? <a href="/contact" class="font-semibold text-brand-700 underline">Plan dan eenvoudig uw onderhoudsbeurt in</a>.
        </p>
      </div>

      <h2 class="section-heading mt-16">Waarom airco-onderhoud loont</h2>
      <div class="mt-8 grid gap-8 sm:grid-cols-2">
        {
          benefits.map((b) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
              <h3 class="text-lg font-semibold text-slate-900">{b.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-600">{b.description}</p>
            </div>
          ))
        }
      </div>

      <div class="mt-16 rounded-2xl border border-brand-200 bg-brand-50 p-8 sm:p-12">
        <p class="text-lg leading-relaxed text-slate-700">
          Nog geen airco, maar wel interesse? Wij verzorgen ook de complete
          <a href="/airco-installatie" class="font-semibold text-brand-700 underline">installatie van uw airco</a>,
          in heel <a href="/airco-installatie-noord-brabant" class="font-semibold text-brand-700 underline">Noord-Brabant</a>.
        </p>
      </div>
    </div>
  </section>

  <section class="border-t border-slate-200 bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="section-heading">Veelgestelde vragen over airco-onderhoud</h2>
      <div class="mt-10">
        <FaqAccordion items={faq} />
      </div>
    </div>
  </section>

  <FaqSchema items={faq} />

  <CTASection
    title="Onderhoud inplannen?"
    description="Neem contact op om uw jaarlijkse onderhoudsbeurt in te plannen. Wij reageren binnen 24 uur."
  />
</BaseLayout>
