---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTASection from '../components/CTASection.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import FaqSchema from '../components/FaqSchema.astro';
import montagePhoto from '../assets/photos/montage-dak.jpg';

const types = [
  {
    title: 'Single-split',
    description:
      'Eén binnenunit gekoppeld aan één buitenunit. Ideaal voor het koelen en verwarmen van één ruimte, zoals de woonkamer of slaapkamer. Een complete installatie start vanaf € 1.299.',
  },
  {
    title: 'Multi-split',
    description:
      'Meerdere binnenunits op één buitenunit. De oplossing als u meerdere kamers wilt voorzien van comfortabele koeling en verwarming, met één net buitendeel.',
  },
];

const included = [
  'Advies aan huis over capaciteit, type en plaatsing',
  'Levering van de airco van een betrouwbaar merk',
  'Vakkundige montage van binnen- en buitenunit',
  'Aansluiten, vacumeren en testen van het systeem',
  'Uitleg over de bediening en het onderhoud',
];

const faq = [
  {
    question: 'Wat kost het om een airco te laten installeren?',
    answer:
      'Een complete installatie start vanaf € 1.299 voor een basis single-split met het voordeligste 2,5 kW-model, inclusief montage. De uiteindelijke prijs hangt af van het model, het aantal ruimtes en de montagesituatie. U ontvangt altijd een vrijblijvende offerte op maat.',
  },
  {
    question: 'Welke merken installeren jullie?',
    answer:
      'Wij installeren airco’s van Daikin, LG en AUX: betrouwbare merken met een goede prijs-kwaliteitverhouding en langdurige garantie.',
  },
  {
    question: 'Hoe lang duurt de installatie?',
    answer:
      'Een standaard single-split plaatsen wij meestal binnen één werkdag. Bij meerdere binnenunits of een complexere situatie plannen wij extra tijd in.',
  },
  {
    question: 'Welke garantie krijg ik?',
    answer:
      'U krijgt 2 tot 5 jaar fabrieksgarantie op de airco (afhankelijk van het merk) en 2 jaar garantie op de installatie, op voorwaarde dat de airco jaarlijks door een vakman wordt onderhouden.',
  },
];
---

<BaseLayout
  title="Airco laten installeren | Best Aircotechniek"
  description="Airco laten installeren door Best Aircotechniek: single- en multi-split van Daikin, LG en AUX. Vakkundige montage in Noord-Brabant, vanaf € 1.299."
>
  <PageHero
    title="Airco laten installeren"
    description="Van persoonlijk advies tot een nette, vakkundige montage. Wij verzorgen de complete installatie van uw airco."
    image={montagePhoto}
  />

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="gold-accent-line"></div>
        <h2 class="section-heading mt-6">Vakkundige airco-installatie</h2>
        <p class="mt-4 text-lg leading-relaxed text-slate-600">
          Een airco zorgt het hele jaar door voor comfort: koel in de zomer en energiezuinig bijverwarmen in het
          tussenseizoen. Best Aircotechniek verzorgt de complete installatie voor particulieren en bedrijven —
          van het eerste advies tot de oplevering. Wij denken met u mee over de juiste capaciteit en de beste plek
          voor de binnen- en buitenunit.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-slate-600">
          Benieuwd hoe ons traject eruitziet? Bekijk
          <a href="/hoe-het-werkt" class="font-semibold text-brand-700 underline">hoe het werkt</a> of vraag direct
          een <a href="/contact" class="font-semibold text-brand-700 underline">vrijblijvende offerte</a> aan.
        </p>
      </div>

      <h2 class="section-heading mt-16">Welk type airco past bij u?</h2>
      <div class="mt-8 grid gap-8 md:grid-cols-2">
        {
          types.map((t) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
              <h3 class="text-xl font-bold text-brand-900">{t.title}</h3>
              <p class="mt-3 leading-relaxed text-slate-600">{t.description}</p>
            </div>
          ))
        }
      </div>

      <div class="mt-16 grid gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <h2 class="section-heading">Wat is bij de installatie inbegrepen?</h2>
          <ul class="mt-6 space-y-3">
            {
              included.map((item) => (
                <li class="flex items-start gap-3 text-slate-600">
                  <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-800 text-white" aria-hidden="true">
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                  </span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="rounded-2xl border border-brand-200 bg-brand-50 p-8">
          <p class="text-sm font-semibold uppercase tracking-wider text-gold-600">Werkgebied</p>
          <p class="mt-2 text-lg leading-relaxed text-slate-700">
            Wij installeren airco’s in heel Noord-Brabant, waaronder Best, Eindhoven, Veldhoven, Tilburg en Den Bosch.
          </p>
          <a href="/airco-installatie-noord-brabant" class="btn-secondary mt-6 inline-flex">Bekijk uw plaats</a>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-slate-200 bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="section-heading">Veelgestelde vragen over airco-installatie</h2>
      <div class="mt-10">
        <FaqAccordion items={faq} />
      </div>
    </div>
  </section>

  <FaqSchema items={faq} />

  <CTASection
    title="Klaar om uw airco te laten installeren?"
    description="Vraag een vrijblijvende offerte aan. Wij reageren binnen 24 uur."
  />
</BaseLayout>
