---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTASection from '../components/CTASection.astro';
import heroPhoto from '../assets/photos/modern-woning-airco.jpg';

const documents = [
  {
    subtitle: 'Productbrochure',
    title: 'AUX airconditioning',
    description:
      'Overzicht van de AUX-wandmodellen Freedom, Q-smart en C-smart: kenmerken, energielabels (SEER/SCOP) en welke capaciteit bij welke ruimte past.',
    href: '/aux-airco-brochure.pdf',
    meta: 'PDF · 5 pagina’s',
  },
];
---

<BaseLayout
  title="Brochures en downloads | Best Aircotechniek"
  description="Download onze brochures en documenten. Bekijk de AUX-productbrochure met alle modellen, kenmerken en capaciteiten."
>
  <PageHero
    title="Brochures en downloads"
    description="Bekijk en download onze brochures en documenten. Wij installeren airco’s van Daikin, LG en AUX; nieuwe documenten voegen we hier toe."
    image={heroPhoto}
  />

  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="gold-accent-line"></div>
      <h2 class="section-heading mt-6">Beschikbare documenten</h2>
      <p class="mt-4 text-lg leading-relaxed text-slate-600">
        Alle bestanden zijn gratis te downloaden als pdf. Heeft u een document of een offerte op maat nodig?
        <a href="/contact" class="font-semibold text-brand-700 underline">Neem contact op</a>.
      </p>

      <div class="mt-10 space-y-5">
        {
          documents.map((doc) => (
            <div class="panel flex flex-col gap-5 p-6 sm:flex-row sm:items-center sm:justify-between">
              <div class="flex items-start gap-4">
                <span
                  class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-brand-50 text-brand-700"
                  aria-hidden="true"
                >
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 0H6.375c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h11.25c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
                    />
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-gold-600">{doc.subtitle}</p>
                  <h3 class="text-xl font-bold text-brand-900">{doc.title}</h3>
                  <p class="mt-2 leading-relaxed text-slate-600">{doc.description}</p>
                  <p class="mt-2 text-sm text-slate-400">{doc.meta}</p>
                </div>
              </div>
              <a
                href={doc.href}
                download
                class="btn-primary inline-flex shrink-0 items-center gap-2 self-start sm:self-auto"
              >
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                </svg>
                Download
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection
    title="Hulp nodig bij uw keuze?"
    description="Wij adviseren u graag over het juiste merk, model en vermogen. Vraag een vrijblijvende offerte aan."
  />
</BaseLayout>
