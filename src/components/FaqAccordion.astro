---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="faq-accordion mx-auto max-w-3xl space-y-3" data-faq-root>
  {
    items.map((item, index) => (
      <div class="overflow-hidden rounded-xl border border-slate-200 bg-white transition-shadow hover:shadow-md">
        <button
          type="button"
          class="faq-trigger flex w-full items-center justify-between gap-4 px-6 py-5 text-left"
          aria-expanded={index === 0 ? 'true' : 'false'}
          aria-controls={`faq-panel-${index}`}
          id={`faq-trigger-${index}`}
          data-faq-trigger={index}
        >
          <span class="font-semibold text-brand-900">{item.question}</span>
          <span
            class="faq-icon flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-50 text-brand-800 transition-transform duration-300"
            aria-hidden="true"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </span>
        </button>
        <div
          id={`faq-panel-${index}`}
          role="region"
          aria-labelledby={`faq-trigger-${index}`}
          class="faq-panel grid transition-[grid-template-rows] duration-300 ease-out"
          data-faq-panel={index}
          hidden={index !== 0}
        >
          <div class="overflow-hidden">
            <p class="px-6 pb-5 leading-relaxed text-slate-600">{item.answer}</p>
          </div>
        </div>
      </div>
    ))
  }
</div>

<style>
  .faq-panel {
    grid-template-rows: 0fr;
  }

  .faq-panel.is-open {
    grid-template-rows: 1fr;
  }

  .faq-panel[hidden] {
    display: none;
  }

  .faq-trigger[aria-expanded='true'] .faq-icon {
    transform: rotate(180deg);
    background-color: #d4af37;
    color: #0f2d47;
  }
</style>

<script>
  function initFaq(root) {
    const triggers = [...root.querySelectorAll('[data-faq-trigger]')];
    const panels = [...root.querySelectorAll('[data-faq-panel]')];

    function closeAll() {
      triggers.forEach((trigger, i) => {
        trigger.setAttribute('aria-expanded', 'false');
        panels[i].hidden = true;
        panels[i].classList.remove('is-open');
      });
    }

    function open(index) {
      closeAll();
      triggers[index].setAttribute('aria-expanded', 'true');
      panels[index].hidden = false;
      requestAnimationFrame(() => panels[index].classList.add('is-open'));
    }

    triggers.forEach((trigger, index) => {
      trigger.addEventListener('click', () => {
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        if (isOpen) closeAll();
        else open(index);
      });
    });

    open(0);
  }

  document.querySelectorAll('[data-faq-root]').forEach((root) => initFaq(root));
</script>
