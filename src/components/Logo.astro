---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { site } from '../data/site';

interface Props {
  size?: 'sm' | 'md' | 'lg';
  /** Above-the-fold / LCP images: eager + high priority. Footer etc.: omit for lazy. */
  priority?: boolean;
  class?: string;
}

const { size = 'md', priority = false, class: className = '' } = Astro.props;

const sizes = {
  sm: { width: 128, height: 128, class: 'h-12 w-12 sm:h-14 sm:w-14' },
  md: { width: 128, height: 128, class: 'h-16 w-16' },
  lg: { width: 640, height: 640, class: 'h-48 w-48 sm:h-64 sm:w-64 lg:h-80 lg:w-80 drop-shadow-2xl' },
} as const;

const { width, height, class: sizeClass } = sizes[size];
---

<Image
  src={logo}
  alt={site.name}
  width={width}
  height={height}
  class:list={['object-contain', sizeClass, className]}
  loading={priority ? 'eager' : 'lazy'}
  fetchpriority={priority ? 'high' : 'auto'}
  decoding={priority ? 'sync' : 'async'}
  sizes={size === 'lg' ? '(min-width: 1024px) 320px, (min-width: 640px) 256px, 192px' : undefined}
/>
