---
import Logo from './Logo.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = site.name,
  subtitle = site.tagline,
} = Astro.props;
---

<section class="page-hero relative overflow-hidden">
  <div class="absolute inset-0 opacity-30">
    <div class="absolute -right-20 -top-20 h-96 w-96 rounded-full bg-gold-400 blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 h-96 w-96 rounded-full bg-brand-600 blur-3xl"></div>
  </div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(212,175,55,0.12),transparent_50%)]"></div>

  <div class="relative mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div class="order-2 lg:order-1">
        <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-gold-500/40 bg-gold-500/10 px-4 py-1.5 text-sm font-semibold text-gold-300">
          <span class="h-1.5 w-1.5 rounded-full bg-gold-400"></span>
          {site.slogan}
        </p>
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">{title}</h1>
        <p class="mt-6 text-lg leading-relaxed text-brand-100 sm:text-xl">{subtitle}</p>
        <div class="mt-10">
          <a href="/contact" class="btn-primary">Neem contact met ons op</a>
        </div>
      </div>
      <div class="order-1 flex justify-center lg:order-2 lg:justify-end">
        <Logo size="lg" priority />
      </div>
    </div>
  </div>
</section>
