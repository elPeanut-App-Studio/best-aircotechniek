---
import { site, nav, dienstenNav } from '../data/site';
import Logo from './Logo.astro';
---

<footer class="border-t-4 border-gold-500 bg-brand-950 text-slate-300">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <div class="flex items-center gap-4">
          <Logo size="md" />
          <div>
            <p class="font-bold uppercase tracking-wide text-white">{site.name}</p>
            <p class="text-sm font-medium text-gold-400">{site.slogan}</p>
          </div>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-slate-400">{site.description}</p>
        <div class="mt-5 flex gap-3">
          <a
            href={site.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${site.name} op Instagram`}
            class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-brand-900 text-slate-300 transition hover:bg-gold-500 hover:text-brand-950"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gold-400">Navigatie</h2>
        <ul class="space-y-2 text-sm">
          {
            nav.map((item) => (
              <li>
                <a href={item.href} class="transition hover:text-gold-300">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gold-400">Diensten</h2>
        <ul class="space-y-2 text-sm">
          {
            dienstenNav.map((item) => (
              <li>
                <a href={item.href} class="transition hover:text-gold-300">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gold-400">Contact</h2>
        <ul class="space-y-2 text-sm">
          <li>
            <a href={`tel:${site.phoneHref}`} class="transition hover:text-gold-300">{site.phone}</a>
          </li>
          <li>
            <a href={`mailto:${site.email}`} class="transition hover:text-gold-300">{site.email}</a>
          </li>
          <li class="text-slate-400">Werkgebied: {site.region}</li>
          <li class="text-slate-400">KVK: {site.kvk}</li>
          <li class="text-slate-400">Btw-id: {site.btwId}</li>
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center gap-1 border-t border-brand-800 pt-6 text-center text-sm text-slate-500">
      <p>&copy; {new Date().getFullYear()} {site.name}. {site.slogan}.</p>
      <p>Website door elPeanut App Studio</p>
    </div>
  </div>
</footer>
