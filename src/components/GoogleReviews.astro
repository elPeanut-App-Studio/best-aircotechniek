---
import { site } from '../data/site';
import { getGoogleReviews, getGoogleWriteReviewUrl } from '../lib/google-reviews';

const data = await getGoogleReviews();
const placeId = import.meta.env.PUBLIC_GOOGLE_PLACE_ID ?? '';
const mapsUrl =
  data?.mapsUrl ??
  site.googleMapsUrl ??
  `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(site.name)}`;
const writeReviewUrl = getGoogleWriteReviewUrl(placeId) ?? mapsUrl;
const hasReviews = data && data.reviews.length > 0;

function stars(rating: number) {
  return Array.from({ length: 5 }, (_, i) => i < Math.round(rating));
}
---

<section class="bg-slate-50 py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <div class="gold-accent-line"></div>
        <h2 class="section-heading mt-6">Wat klanten zeggen</h2>
        <p class="section-subheading max-w-2xl">
          {hasReviews
            ? 'Echte reviews van onze klanten op Google.'
            : 'Bekijk onze reviews op Google of deel uw ervaring met ons.'}
        </p>
      </div>

      {
        hasReviews && data && (
          <div class="flex shrink-0 items-center gap-4 rounded-2xl border border-slate-200 bg-white px-6 py-4 shadow-sm">
            <div class="text-center">
              <p class="text-4xl font-bold text-brand-900">{data.rating.toFixed(1)}</p>
              <div class="mt-1 flex justify-center gap-0.5" aria-label={`${data.rating} van 5 sterren`}>
                {
                  stars(data.rating).map((filled) => (
                    <svg
                      class:list={['h-5 w-5', filled ? 'text-gold-500' : 'text-slate-300']}
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))
                }
              </div>
              <p class="mt-1 text-sm text-slate-500">{data.totalReviews} reviews op Google</p>
            </div>
            <svg class="h-8 w-8 shrink-0" viewBox="0 0 24 24" aria-label="Google" role="img">
              <path
                fill="#4285F4"
                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
              />
              <path
                fill="#34A853"
                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
              />
              <path
                fill="#FBBC05"
                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
              />
              <path
                fill="#EA4335"
                d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
              />
            </svg>
          </div>
        )
      }
    </div>

    {
      hasReviews && data ? (
        <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {
            data.reviews.map((review) => (
              <article class="flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="flex items-start gap-3">
                  {
                    review.authorPhoto ? (
                      <img
                        src={review.authorPhoto}
                        alt=""
                        width="40"
                        height="40"
                        class="h-10 w-10 shrink-0 rounded-full object-cover"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <span
                        class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-100 text-sm font-bold text-brand-800"
                        aria-hidden="true"
                      >
                        {review.authorName.charAt(0)}
                      </span>
                    )
                  }
                  <div class="min-w-0">
                    <p class="font-semibold text-brand-900">{review.authorName}</p>
                    <p class="text-xs text-slate-500">{review.relativeTime}</p>
                  </div>
                </div>
                <div class="mt-3 flex gap-0.5" aria-label={`${review.rating} van 5 sterren`}>
                  {
                    stars(review.rating).map((filled) => (
                      <svg
                        class:list={['h-4 w-4', filled ? 'text-gold-500' : 'text-slate-200']}
                        viewBox="0 0 20 20"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    ))
                  }
                </div>
                <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-600">{review.text}</p>
              </article>
            ))
          }
        </div>
      ) : (
        <div class="mt-10 rounded-2xl border border-slate-200 bg-white p-8 text-center shadow-sm sm:p-12">
          <svg class="mx-auto h-10 w-10" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="#4285F4"
              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
            />
            <path
              fill="#34A853"
              d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
            />
            <path
              fill="#FBBC05"
              d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
            />
            <path
              fill="#EA4335"
              d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
            />
          </svg>
          <p class="mt-4 text-lg text-slate-600">
            Bekijk wat klanten over ons zeggen op Google.
          </p>
        </div>
      )
    }

    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href={mapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary"
      >
        Bekijk op Google
      </a>
      <a
        href={writeReviewUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
      >
        Schrijf een review
      </a>
    </div>
  </div>
</section>
