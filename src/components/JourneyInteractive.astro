---
import { journey } from '../data/site';

interface Props {
  steps?: typeof journey;
}

const { steps = journey } = Astro.props;

const icons = [
  `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />`,
  `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />`,
  `<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />`,
  `<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />`,
  `<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" />`,
  `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />`,
];
---

<div class="journey-interactive" data-journey-root>
  <div class="mb-8">
    <div class="h-2 overflow-hidden rounded-full bg-brand-100">
      <div
        class="h-full rounded-full bg-gradient-to-r from-gold-400 to-gold-500 transition-all duration-500 ease-out"
        data-progress
        style={`width: ${100 / steps.length}%`}
      >
      </div>
    </div>
  </div>

  <!-- Mobiel & tablet: accordion -->
  <div class="flex flex-col gap-3 lg:hidden" data-journey-mobile>
    {
      steps.map((step, index) => (
        <div
          class:list={[
            'overflow-hidden rounded-xl border transition-all duration-300',
            index === 0 ? 'border-gold-300 bg-brand-50 shadow-md ring-2 ring-gold-200' : 'border-slate-200 bg-white',
          ]}
          data-mobile-item={index}
        >
          <button
            type="button"
            aria-expanded={index === 0 ? 'true' : 'false'}
            data-mobile-trigger={index}
            class="flex w-full items-center gap-4 p-4 text-left"
          >
            <span
              class:list={[
                'flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-sm font-bold transition-transform duration-300',
                index === 0
                  ? 'scale-110 bg-brand-800 text-white ring-4 ring-gold-200'
                  : 'bg-brand-100 text-brand-800',
              ]}
              data-step-badge
            >
              {index + 1}
            </span>
            <span class="min-w-0 flex-1 font-semibold text-brand-900">{step.title}</span>
            <span
              class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white/80 text-brand-800 transition-transform duration-300"
              data-chevron
              aria-hidden="true"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </span>
          </button>
          <div
            class:list={['journey-mobile-content grid transition-[grid-template-rows] duration-300 ease-out', index === 0 ? 'is-open' : '']}
            data-mobile-content={index}
          >
            <div class="overflow-hidden">
              <div class="border-t border-brand-100 px-4 pb-5 pt-4">
                <div class="flex gap-4">
                  <div
                    class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-brand-800 to-brand-900 text-white"
                    aria-hidden="true"
                  >
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <Fragment set:html={icons[index]} />
                    </svg>
                  </div>
                  <p class="text-base leading-relaxed text-slate-600">{step.description}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <!-- Desktop: stappen links, detail rechts -->
  <div class="hidden gap-6 lg:grid lg:grid-cols-5 lg:items-stretch lg:gap-8" data-journey-desktop>
    <div class="flex flex-col gap-2 lg:col-span-2 lg:h-full" role="tablist" aria-label="Stappen klantreis">
      {
        steps.map((step, index) => (
          <button
            type="button"
            role="tab"
            id={`journey-tab-${index}`}
            aria-controls={`journey-panel-${index}`}
            aria-selected={index === 0 ? 'true' : 'false'}
            tabindex={index === 0 ? 0 : -1}
            data-desktop-step={index}
            class:list={[
              'journey-tab group flex w-full items-center gap-4 rounded-xl border p-4 text-left transition-all duration-300 lg:flex-1 lg:px-5',
              index === 0
                ? 'border-gold-300 bg-brand-50 shadow-md ring-2 ring-gold-200'
                : 'border-slate-200 bg-white hover:border-brand-100 hover:bg-slate-50',
            ]}
          >
            <span
              class:list={[
                'flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-sm font-bold transition-transform duration-300',
                index === 0
                  ? 'scale-110 bg-brand-800 text-white ring-4 ring-gold-200'
                  : 'bg-brand-100 text-brand-800 group-hover:bg-brand-800 group-hover:text-white',
              ]}
              data-step-badge
            >
              {index + 1}
            </span>
            <span class="min-w-0">
              <span class="block font-semibold text-brand-900">{step.title}</span>
            </span>
          </button>
        ))
      }
    </div>

    <div class="relative flex min-h-[22rem] flex-col lg:col-span-3 lg:h-full">
      {
        steps.map((step, index) => (
          <div
            role="tabpanel"
            id={`journey-panel-${index}`}
            aria-labelledby={`journey-tab-${index}`}
            data-desktop-panel={index}
            hidden={index !== 0}
            class:list={[
              'journey-panel flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-8 shadow-lg sm:p-10',
              index === 0 ? 'is-active' : '',
            ]}
          >
            <div class="flex flex-1 flex-col gap-6 sm:flex-row sm:items-start sm:gap-8">
              <div
                class="inline-flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-brand-800 to-brand-900 text-white shadow-lg sm:h-20 sm:w-20"
                aria-hidden="true"
              >
                <svg class="h-8 w-8 sm:h-10 sm:w-10" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <Fragment set:html={icons[index]} />
                </svg>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold uppercase tracking-wide text-gold-600">Stap {index + 1}</p>
                <h3 class="mt-2 text-2xl font-bold text-brand-900 sm:text-3xl">{step.title}</h3>
                <p class="mt-4 text-lg leading-relaxed text-slate-600">{step.description}</p>
              </div>
            </div>

            <div
              class:list={[
                'mt-auto flex items-center gap-4 border-t border-slate-100 pt-6',
                index === 0 ? 'justify-end' : index === steps.length - 1 ? 'justify-start' : 'justify-between',
              ]}
            >
              {
                index > 0 && (
                  <button
                    type="button"
                    data-prev
                    class="inline-flex items-center gap-2 rounded-lg border border-brand-200 px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:border-gold-400 hover:bg-brand-50"
                  >
                    Vorige
                  </button>
                )
              }
              {
                index < steps.length - 1 && (
                  <button
                    type="button"
                    data-next
                    class="inline-flex items-center gap-2 rounded-lg bg-brand-800 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-900"
                  >
                    Volgende
                  </button>
                )
              }
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .journey-mobile-content {
    grid-template-rows: 0fr;
  }

  .journey-mobile-content.is-open {
    grid-template-rows: 1fr;
  }

  .journey-panel[hidden] {
    display: none;
  }

  .journey-panel.is-active {
    animation: panel-in 0.45s ease-out;
  }

  [data-mobile-item][data-active='true'] [data-chevron] {
    transform: rotate(180deg);
    background-color: #d4af37;
    color: #0f2d47;
  }

  @keyframes panel-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script define:vars={{ stepCount: steps.length }}>
  function initJourney(root) {
    const progress = root.querySelector('[data-progress]');
    const mobileItems = [...root.querySelectorAll('[data-mobile-item]')];
    const mobileTriggers = [...root.querySelectorAll('[data-mobile-trigger]')];
    const desktopTabs = [...root.querySelectorAll('[data-desktop-step]')];
    const desktopPanels = [...root.querySelectorAll('[data-desktop-panel]')];
    let current = 0;

    function setBadgeStyles(badge, active) {
      if (!badge) return;
      badge.classList.toggle('scale-110', active);
      badge.classList.toggle('bg-brand-800', active);
      badge.classList.toggle('text-white', active);
      badge.classList.toggle('ring-4', active);
      badge.classList.toggle('ring-gold-200', active);
      badge.classList.toggle('bg-brand-100', !active);
      badge.classList.toggle('text-brand-800', !active);
    }

    function setDesktopTabStyles(tab, active) {
      tab.setAttribute('aria-selected', String(active));
      tab.tabIndex = active ? 0 : -1;
      tab.classList.toggle('border-gold-300', active);
      tab.classList.toggle('bg-brand-50', active);
      tab.classList.toggle('shadow-md', active);
      tab.classList.toggle('ring-2', active);
      tab.classList.toggle('ring-gold-200', active);
      tab.classList.toggle('border-slate-200', !active);
      tab.classList.toggle('bg-white', !active);
      setBadgeStyles(tab.querySelector('[data-step-badge]'), active);
    }

    function setMobileItemStyles(item, active) {
      item.setAttribute('data-active', String(active));
      item.classList.toggle('border-gold-300', active);
      item.classList.toggle('bg-brand-50', active);
      item.classList.toggle('shadow-md', active);
      item.classList.toggle('ring-2', active);
      item.classList.toggle('ring-gold-200', active);
      item.classList.toggle('border-slate-200', !active);
      item.classList.toggle('bg-white', !active);

      const trigger = item.querySelector('[data-mobile-trigger]');
      const content = item.querySelector('[data-mobile-content]');
      if (trigger) trigger.setAttribute('aria-expanded', String(active));
      if (content) content.classList.toggle('is-open', active);
      setBadgeStyles(item.querySelector('[data-step-badge]'), active);
    }

    function goTo(index) {
      current = Math.max(0, Math.min(index, stepCount - 1));

      mobileItems.forEach((item, i) => setMobileItemStyles(item, i === current));

      desktopTabs.forEach((tab, i) => setDesktopTabStyles(tab, i === current));
      desktopPanels.forEach((panel, i) => {
        const isActive = i === current;
        panel.hidden = !isActive;
        panel.classList.toggle('is-active', isActive);
      });

      if (progress) progress.style.width = `${((current + 1) / stepCount) * 100}%`;
    }

    mobileTriggers.forEach((trigger, i) => {
      trigger.addEventListener('click', () => {
        if (current === i) return;
        goTo(i);
      });
    });

    desktopTabs.forEach((tab, i) => tab.addEventListener('click', () => goTo(i)));

    root.querySelectorAll('[data-prev]').forEach((btn) => {
      btn.addEventListener('click', () => goTo(current - 1));
    });
    root.querySelectorAll('[data-next]').forEach((btn) => {
      btn.addEventListener('click', () => goTo(current + 1));
    });

    goTo(0);
  }

  document.querySelectorAll('[data-journey-root]').forEach((root) => initJourney(root));
</script>
