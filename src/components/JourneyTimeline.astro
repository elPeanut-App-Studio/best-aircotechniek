---
import { journey } from '../data/site';

interface Props {
  steps?: typeof journey;
  showAll?: boolean;
}

const { steps = journey, showAll = true } = Astro.props;
const visibleSteps = showAll ? steps : steps.slice(0, 3);
---

<ol class="relative space-y-0">
  {
    visibleSteps.map((step, index) => (
      <li class="relative flex gap-6 pb-12 last:pb-0">
        {index < visibleSteps.length - 1 && (
          <span
            class="absolute left-6 top-14 h-[calc(100%-3.5rem)] w-0.5 -translate-x-1/2 bg-gradient-to-b from-gold-400 to-brand-200"
            aria-hidden="true"
          />
        )}
        <div class="relative z-10 flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand-800 text-sm font-bold text-white ring-4 ring-gold-200">
          {index + 1}
        </div>
        <div class="pt-1">
          <h3 class="text-xl font-bold text-brand-900">{step.title}</h3>
          <p class="mt-2 max-w-2xl leading-relaxed text-slate-600">{step.description}</p>
        </div>
      </li>
    ))
  }
</ol>
