---
import { site, serviceAreas } from '../data/site';
import { getGoogleReviews } from '../lib/google-reviews';

const reviewsData = await getGoogleReviews();

const logoUrl = new URL(site.logo, site.url).href;
const imageUrl = new URL(site.ogImage, site.url).href;

const schema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'HVACBusiness',
  '@id': `${site.url}/#business`,
  name: site.name,
  description: site.description,
  url: site.url,
  logo: logoUrl,
  image: imageUrl,
  telephone: site.phoneHref,
  email: site.email,
  // Concrete plaatsen i.p.v. één vrije tekst — beter voor lokale relevantie.
  areaServed: serviceAreas.map((place) => ({ '@type': 'City', name: place })),
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'Noord-Brabant',
    addressCountry: 'NL',
  },
  taxID: site.btwId,
  identifier: {
    '@type': 'PropertyValue',
    propertyID: 'KVK',
    value: site.kvk,
  },
  priceRange: '€€',
};

if (reviewsData && reviewsData.rating > 0 && reviewsData.totalReviews > 0) {
  schema.aggregateRating = {
    '@type': 'AggregateRating',
    ratingValue: reviewsData.rating,
    reviewCount: reviewsData.totalReviews,
    bestRating: 5,
    worstRating: 1,
  };
}

// sameAs: Google Maps + overige profielen, ontdubbeld en lege waarden eruit.
const sameAs = [site.googleMapsUrl, ...site.sameAs].filter(Boolean);
if (sameAs.length > 0) {
  schema.sameAs = [...new Set(sameAs)];
}

// Openingstijden alleen tonen als ze bevestigd/ingevuld zijn (zie src/data/site.ts).
if (site.openingHours.length > 0) {
  schema.openingHoursSpecification = site.openingHours.map((slot) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: slot.days,
    opens: slot.opens,
    closes: slot.closes,
  }));
}
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
