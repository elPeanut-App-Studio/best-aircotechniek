---
import JourneyInteractive from './JourneyInteractive.astro';
---

<section class="bg-slate-50 py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <div class="gold-accent-line"></div>
      <h2 class="section-heading mt-6">Hoe het werkt</h2>
      <p class="section-subheading">
        In een paar duidelijke stappen van eerste contact naar een werkende airco in huis.
      </p>
    </div>

    <div class="mt-12">
      <JourneyInteractive />
    </div>
  </div>
</section>
